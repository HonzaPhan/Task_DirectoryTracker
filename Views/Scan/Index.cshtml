@using Task_DirectoryTracker.Models.ViewModels
@using Task_DirectoryTracker.Models.Entities

@model ScanPageViewModel

@{
    ViewData["Title"] = "Directory Scanner";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Directory Tracker</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="post" class="row g-3" id="scan-form">
                <div class="col-12">
                    <label asp-for="Request.Path" class="form-label">Cesta k adresáři</label>
                    <input asp-for="Request.Path" class="form-control" placeholder="C:\test\folder" />
                    <span asp-validation-for="Request.Path" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary" id="scan-btn">
                        <span id="btn-idle">Spustit analýzu</span>
                        <span id="btn-loading" class="d-none">
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            Probíhá analýza...
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    @{
        ScanResult r = Model.Result ?? new ScanResult();
        string fileChangeCardPath = "Shared/_FileChangeCard";
        string stringListCardPath = "Shared/_StringListCard";
    }

    <h2 class="h4 mb-3">Výsledek analýzy</h2>

    <div class="row g-3">
        <div class="col-md-6">
            @await Html.PartialAsync(fileChangeCardPath, new FileChangeCardViewModel
            {
                Title = "Nové soubory",
                Emoji = "🟢",
                BorderClass = "success",
                HeaderClass = "bg-success text-white",
                EmptyMessage = "Žádné nové soubory.",
                Files = r.AddedFiles
            })
        </div>
        <div class="col-md-6">
            @await Html.PartialAsync(fileChangeCardPath, new FileChangeCardViewModel
            {
                Title = "Změněné soubory",
                Emoji = "🟡",
                BorderClass = "warning",
                HeaderClass = "bg-warning text-dark",
                EmptyMessage = "Žádné změněné soubory.",
                Files = r.ModifiedFiles
            })
        </div>
        <div class="col-md-6">
            @await Html.PartialAsync(stringListCardPath, new StringListCardViewModel
            {
                Title = "Smazané soubory",
                Emoji = "🔴",
                BorderClass = "danger",
                HeaderClass = "bg-danger text-white",
                EmptyMessage = "Žádné smazané soubory.",
                Items = r.DeletedFiles
            })
        </div>
        <div class="col-md-6">
            @await Html.PartialAsync(stringListCardPath, new StringListCardViewModel
            {
                Title = "Smazané adresáře",
                Emoji = "📁",
                BorderClass = "secondary",
                HeaderClass = "bg-secondary text-white",
                EmptyMessage = "Žádné smazané adresáře.",
                Items = r.DeletedDirectories
            })
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/scan.js"></script>
}