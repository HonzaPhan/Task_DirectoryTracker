@using Task_DirectoryTracker.Models.Entities
@using Task_DirectoryTracker.Models.ViewModels

@model FileChangeCardViewModel

<div class="card border-@Model.BorderClass h-100">
    <div class="card-header @Model.HeaderClass">
        @Model.Emoji @Model.Title
    </div>
    <div class="card-body scan-card-body">
        @if (Model.HasItems)
        {
            <ul class="list-group list-group-flush">
                @foreach (FileChange file in Model.Files)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-truncate me-2" title="@file.Path">@file.Path</span>
                        <span class="badge bg-secondary flex-shrink-0">verze @file.Version</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">@Model.EmptyMessage</p>
        }
    </div>
</div>
